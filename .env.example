# Скопируйте в .env и подставьте значения для сервера.
# Приложение и Alembic читают настройки только отсюда / из переменных окружения.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE

# --- Redis ---
REDIS_URL=redis://HOST:6379/0
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# --- JWT (SECRET_KEY не короче 16 символов) ---
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_NAME=Messenger
DEBUG=False
API_V1_PREFIX=/api/v1

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=True

# --- CORS (через запятую) ---
# Добавьте адрес фронтенда, например http://150.241.97.172:3000
CORS_ORIGINS=https://your-frontend.com,http://localhost:5173,http://150.241.97.172:3000
